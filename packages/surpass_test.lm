display "==============================================="
display " EVL EMPIRE: Surpass Benchmark - RPG Logic     "
display "==============================================="

define action calculatePlayerStats with level and classType
    set local health to 0
    set local mana to 0
    
    if classType is "Warrior" then
        set health to 150
        set mana to 20
    end
    
    if classType is "Mage" then
        set health to 75
        set mana to 200
    end

    multiply health by level
    multiply mana by level
    
    return health
end

define action generateLootDrop with enemyLevel
    set local rarity to "Common"
    
    if enemyLevel is greater than 50 then
        set rarity to "Legendary"
    end
    
    if enemyLevel is greater than 90 then
        set rarity to "MYTHIC"
    end
    
    return rarity
end

display "Initializing MMORPG Server Logic..."

set playerClass to "Mage"
set playerLevel to 42

set maxHealth to perform calculatePlayerStats with playerLevel and playerClass
display "Player [ {playerClass} LVL {playerLevel} ] spawned with {maxHealth} HP."

set loot to perform generateLootDrop with 95
display "Defeated the World Boss! Dropped: {loot} WEAPON!"

display "RPG Logic Engine Surpass Benchmark: PASSED"
